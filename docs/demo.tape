# Regenerate the demo GIF:  npm i -g ai-coding-stack && vhs docs/demo.tape
Output docs/demo.gif
Set Shell bash
Set FontSize 16
Set Width 1100
Set Height 720
Set Padding 20
Set Theme "Dracula"
Hide
Type "cd /tmp && rm -rf billing-api && mkdir billing-api && cd billing-api && printf 'module billing-api\ngo 1.22\n' > go.mod && export PS1='$ ' && clear"
Enter
Show
Sleep 600ms
Type "# scaffold any project for Claude Code, Codex & Antigravity"
Enter
Sleep 1s
Type "aics-init . --about 'REST API with Stripe webhooks'"
Enter
Sleep 2500ms
Type "ls"
Enter
Sleep 1500ms
Type "sed -n '1,14p' AGENTS.md"
Enter
Sleep 3500ms
